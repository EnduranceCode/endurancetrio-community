#
# Environment Configuration Template
# ==================================
#
# This file serves as a template for the .env file that contains all environment-specific
# configuration including sensitive information like database credentials and secrets.
#
# IMPORTANT SECURITY NOTES:
# - Copy this file to .env and NEVER commit the .env file to version control
# - The .env file is automatically excluded via .gitignore for security
# - For production deployments, consider using Docker Secrets or a proper secret manager
#
# Usage Instructions:
# -------------------
# Step 1: Copy this template to create the .env file, using the following command:
#         cp .env-template .env
#
# Step 2: Fill in all the variables values with the actual required configuration
#
# Step 3: Ensure that .env file is listed in the .gitignore file
#

# Container Image Configuration
# -----------------------------
# STG_VERSION: Container image version tag from GitHub Container Registry for staging
# Format: sha-<commit_hash>-<suffix> (from workflow_dispatch)
# Example: STG_VERSION=sha-abc1234-stg-fix-login
STG_VERSION=

# PRD_VERSION: Container image version tag from GitHub Container Registry for production
# Format: X.Y.Z (semantic version from a GitHub release)
# Example: PRD_VERSION=1.0.0
PRD_VERSION=

# Container Security & User Context
# ---------------------------------
# PUID: User ID under which the container process runs
# Purpose: Controls file permissions for volumes and security context
# Recommendation: Use non-root user for security
PUID=

# PGID: Group ID under which the container process runs
# Purpose: Controls group permissions for volumes and process security
# Recommendation: Match PUID with corresponding group
PGID=

# Application Profile & Port Configuration
# ----------------------------------------
# STG_ENDURANCETRIO_EXT_PORT: External port on the Docker host for accessing the staging app
# Purpose: Maps the container's service port to a port on the host machine
# Note: Must be different from PRD_ENDURANCETRIO_EXT_PORT to avoid port conflicts
# Format: Any available port number (1024-65535)
STG_ENDURANCETRIO_EXT_PORT=

# PRD_ENDURANCETRIO_EXT_PORT: External port on the Docker host for accessing the production app
# Purpose: Maps the container's service port to a port on the host machine
# Format: Any available port number (1024-65535)
# Security: Ensure this port is properly firewalled in production
PRD_ENDURANCETRIO_EXT_PORT=

# STG_JAVA_XMS: Initial JVM heap size (-Xms) for the staging container
# Purpose: Controls the initial JVM heap allocation for the staging application
# Format: <number>m or <number>g (e.g., 512m, 1g)
# Default: 512m
STG_JAVA_XMS=

# STG_JAVA_XMX: Maximum JVM heap size (-Xmx) for the staging container
# Purpose: Controls the maximum JVM heap allocation for the staging application
# Format: <number>m or <number>g (e.g., 768m, 1g)
# Default: 768m
STG_JAVA_XMX=

# PRD_JAVA_XMS: Initial JVM heap size (-Xms) for the production container
# Purpose: Controls the initial JVM heap allocation for the production application
# Format: <number>m or <number>g (e.g., 768m, 1g)
# Default: 768m
PRD_JAVA_XMS=

# PRD_JAVA_XMX: Maximum JVM heap size (-Xmx) for the production container
# Purpose: Controls the maximum JVM heap allocation for the production application
# Format: <number>m or <number>g (e.g., 1024m, 1g)
# Default: 1024m
PRD_JAVA_XMX=

# Database Configuration
# ----------------------
# DB_ROOT_PASSWORD: Password for the PostgreSQL superuser (postgres)
# This is used during PostgreSQL initial database setup
#
# Security Protocol:
# This sensitive value can be provided as a temporary environment variable
# instead of being persisted in the .env file.
#
# Operational Note:
# It is required whenever PostgreSQL is initialized from an empty data directory
# (first deployment or volume recreation).
#
# Usage:
#   Step 1: Temporarily set the variable from your password manager:
#           export DB_ROOT_PASSWORD=<strong_password_here>
#   Step 2: Start PostgreSQL (or full stack):
#           docker compose -p endurancetrio-community up -d postgres
#   Step 3: Confirm successful initialization:
#           docker logs endurancetrio-postgres
#   Step 4: Immediately clear the variable value from memory:
#           unset DB_ROOT_PASSWORD

# POSTGRES_EXT_PORT: Host loopback port mapped to the PostgreSQL container
# Purpose: Allows local host access for tools like DBeaver via SSH tunnel
# Security: Bound to 127.0.0.1 in docker-compose, so it is not exposed to the internet
# Format: Any available port number (1024-65535)
# Default: 5432
POSTGRES_EXT_PORT=

# STG_DB_URL: JDBC connection URL for the staging database
# Format: jdbc:postgresql://host:port/database_name
# Example: jdbc:postgresql://postgres:5432/stg_endurancetrio_community
STG_DB_URL=

# STG_DB_USERNAME: Database username for the staging application database connections
STG_DB_USERNAME=

# STG_DB_SECRET: Database password for the staging user
STG_DB_SECRET=

# PRD_DB_URL: JDBC connection URL for the production database
# Format: jdbc:postgresql://host:port/database_name
# Example: jdbc:postgresql://postgres:5432/prd_endurancetrio_community
PRD_DB_URL=

# PRD_DB_USERNAME: Database username for the production application database connections
# This user should have appropriate permissions for the production database
PRD_DB_USERNAME=

# PRD_DB_SECRET: Database password for the production user
# Ensure this is a strong password and kept secure
PRD_DB_SECRET=

# CORS Configuration
# ------------------
# STG_CORS_ALLOWED_ORIGINS: Comma-separated list of allowed CORS origins for staging
# Purpose: Controls which web origins are permitted to make cross-origin requests to the API
# Security: Restrict to specific trusted domains
STG_CORS_ALLOWED_ORIGINS=

# PRD_CORS_ALLOWED_ORIGINS: Comma-separated list of allowed CORS origins for production
# Purpose: Controls which web origins are permitted to make cross-origin requests to the API
# Format: Comma-separated URLs without spaces; Must include protocol (http/https) and port
#         if non-standard (not 80/443)
# Security: Restrict to specific trusted domains in production; avoid wildcards (*)
PRD_CORS_ALLOWED_ORIGINS=

# Featured Articles Configuration
# -------------------------------
# FEATURED_ARTICLE_IDS: Comma-separated list of article IDs to display as featured articles on the
# homepage.
# Format: Comma-separated numeric IDs (e.g., 1,2,5)
# Default: 1,2
FEATURED_ARTICLE_IDS=

# Ko-fi & Social Configuration
# -----------------------------
# KOFI_USER_ID: Ko-fi user ID for the donation button
KOFI_USER_ID=

# FACEBOOK_PAGE_ID: Facebook Page ID for Open Graph meta tags
FACEBOOK_PAGE_ID=

# TWITTER_SITE: Twitter/X site handle for Twitter Card meta tags
TWITTER_SITE=

# GOOGLE_ADSENSE_ID: Google AdSense publisher ID for site verification meta tag
GOOGLE_ADSENSE_ID=

# Kit Newsletter Configuration
# --------------------------
# KIT_API_KEY: Kit.com API key for newsletter integration
# Purpose: Authenticates requests to the Kit.com v4 API for managing newsletter subscriptions
# How to obtain: Log in at kit.com → Settings → Developer Settings → API Keys.
#                Copy the Live API Key or generate a new one if needed
# Security: Keep this key secure; it provides full API access to your Kit.com account
KIT_API_KEY=

# KIT_FORM_ID_EN: Kit.com form ID for the English newsletter subscription form
# Purpose: Identifies which Kit.com form to add English-speaking subscribers to, triggering
#          the double opt-in email configured on that form in Kit.com
# How to obtain: Kit.com → Grow → Landing Pages & Forms → open the English form → copy the
#                numeric ID from the browser URL (e.g., https://app.kit.com/forms/1234567)
KIT_FORM_ID_EN=

# KIT_FORM_ID_PT: Kit.com form ID for the Portuguese newsletter subscription form
# Purpose: Identifies the Portuguese-language subscription form for subscriber routing.
#          Follows the same double opt-in workflow as the English form
# How to obtain: Same process as KIT_FORM_ID_EN, but for the Portuguese language form
KIT_FORM_ID_PT=

# First Tracker Account Initialization
# ------------------------------------
# These variables are used for automatic creation of the initial tracker account
# on first application startup. Check the "API Key Management" section of the README.md file for
# further information.
#
# FIRST_OWNER: The display name/identifier for the first tracker account
# This will be the owner name shown in the tracking system
FIRST_OWNER=

# FIRST_HASH: The cryptographic hash of the tracker key/password
# This must be a securely hashed version of the first account authentication key
#
# Security Protocol:
# This sensitive value should be provided as a temporary environment variable
# rather than persisted in the .env file to reduce attack surface.
#
# Usage:
#   Step 1: Temporarily set the variable:
#           export FIRST_HASH=key_hash_here
#   Step 2: Deploy the application:
#           docker compose -p endurancetrio-community up -d
#   Step 3: Check the logs and ensure that the application initialization is completed:
#           docker logs endurancetrio-community
#   Step 4: Immediately clear the variable value from memory:
#           unset FIRST_HASH
#
