{
  "name": "endurancetrio-community",
  "version": "0.0.1",
  "description": "A central hub for endurance sports data and resources",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build:dev": "webpack --mode development",
    "build:prod": "webpack --mode production",
    "format": "npm run format:prettier && npm run format:eslint",
    "format:prettier": "prettier --write '**/*.{css,scss,json,md}'",
    "format:eslint": "eslint . --ext .js --fix"
  },
  "keywords": [
    "HTML",
    "CSS",
    "Sass",
    "JavaScript",
    "webpack"
  ],
  "author": "Ricardo do Canto <endurancecode@endurancecode.com>",
  "license": "LicenseRef-Functional-Software-License-(FSL)-1.1-ALv2-Future-License",
  "devDependencies": {
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "mini-css-extract-plugin": "^2.10.2",
    "postcss": "^8.5.14",
    "postcss-loader": "^8.2.1",
    "postcss-preset-env": "^11.3.0",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.8",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "bulma": "^1.0.4",
    "klaro": "^0.7.21"
  }
