# This file serves as the environment configuration of the script
# deploy-endurancetrio-javadoc-to-prod.sh that should be executed on the production server.
#
# Usage:
#   1. Copy this file to the home folder of the server with the command:
#        wget -P ~/ https://raw.githubusercontent.com/EnduranceCode/endurancetrio-community/refs/heads/master/apache/scripts/.env-prod-endurancetrio-javadoc
#   2. Edit the file and set the correct values for the required variables

# Temporary path on the production server where files were staged
# Must be an absolute path
DEPLOY_STAGING_FOLDER=/tmp/apidocs

# Final location for website files
# Must be an absolute path
WEB_ROOT=/srv/www/endurancetrio-docs

# Backup directory
# Must be an absolute path
# Consider changing `~` to an absolute path like `/home/username/deployment-backups`
# to avoid issues with cron jobs
BACKUP_FOLDER=~/deployment-backups

# Permissions (user:group)
FILE_OWNER=${USER}:www-data
